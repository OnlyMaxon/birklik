rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check moderator role
    function isModerator() {
      return request.auth != null && request.auth.token.moderator == true;
    }

    // Helper function to check property ownership
    function isOwner(ownerId) {
      return request.auth != null && request.auth.uid == ownerId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['moderator', 'admin']);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /properties/{propertyId} {
      allow read: if true;

      // Create: owner must match auth user
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Update: owner, favorites/views update, or moderator
      allow update: if request.auth != null && (
        // Owner can update (except ownerId, createdAt, updatedAt)
        (isOwner(resource.data.ownerId) && !request.resource.data.keys().hasAny(['ownerId', 'createdAt', 'updatedAt']))
        // Anyone authenticated can update favorites or views only
        || (request.resource.data.keys().size() == 1 && ('favorites' in request.resource.data || 'views' in request.resource.data))
        // Moderator can update anything
        || isModerator()
      );

      // Delete: owner or moderator
      allow delete: if request.auth != null && (
        isOwner(resource.data.ownerId) || isModerator()
      );
    }

    match /properties/{propertyId}/comments/{commentId} {
      allow read: if true;
      
      // Create: user must match auth user
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      
      // Update: only comment author, or can update specific fields
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || isModerator()
      );
      
      // Delete: comment author or moderator
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId || isModerator()
      );
    }

    match /bookings/{bookingId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.propertyOwner
      );
      
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId || isModerator()
      );
    }
  }
}