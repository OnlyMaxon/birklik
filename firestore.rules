rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check moderator role
    function isModerator() {
      return request.auth != null && request.auth.token.moderator == true;
    }

    // Helper function to check property ownership
    function isOwner(ownerId) {
      return request.auth != null && request.auth.uid == ownerId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['moderator', 'admin']);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /properties/{propertyId} {
      allow read: if true;

      // Create: owner must match auth user
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Update: owner OR any authenticated user for views/likes/favorites/comments
      allow update: if request.auth != null && (
        // Owner can update anything except critical fields
        (isOwner(resource.data.ownerId) && !request.resource.data.keys().hasAny(['ownerId', 'createdAt']))
        // Any authenticated user can update views, likes, favorites, comments
        || (request.resource.data.keys().hasAny(['views', 'likes', 'favorites', 'comments']))
        // Moderator can update anything
        || isModerator()
      );

      // Delete: owner or moderator
      allow delete: if request.auth != null && (
        isOwner(resource.data.ownerId) || isModerator()
      );
    }

    match /properties/{propertyId}/comments/{commentId} {
      allow read: if true;
      
      // Create: user must match auth user
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      
      // Update: only comment author or moderator
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || isModerator()
      );
      
      // Delete: comment author or moderator
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId || isModerator()
      );
    }

    match /bookings/{bookingId} {
      // Read: user can read their own bookings OR property owner can read bookings for their properties
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || isOwner(get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId)
      );
      
      // Create: user booking must be created by the authenticated user
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.keys().hasAny(['propertyId', 'checkInDate', 'checkOutDate', 'totalPrice', 'nights', 'userName', 'userEmail', 'userPhone']);
      
      // Update: only user or property owner can update, and only status field
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.userId && request.resource.data.status != resource.data.status)
        || (isOwner(get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId) && request.resource.data.status != resource.data.status)
      );
      
      // Delete: user can cancel their own booking, or property owner/moderator can delete
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId 
        || isOwner(get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId)
        || isModerator()
      );
    }
  }
}