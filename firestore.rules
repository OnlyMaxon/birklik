rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check moderator role
    function isModerator() {
      return request.auth != null && request.auth.token.moderator == true;
    }

    // Helper function to check property ownership
    function isOwner(ownerId) {
      return request.auth != null && request.auth.uid == ownerId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['moderator', 'admin']);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /properties/{propertyId} {
      allow read: if true;

      // Create: owner must match auth user
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Update: Owner can update allowed fields, Moderator can do anything, Users can ONLY increment counters atomically or add ratings
      allow update: if request.auth != null && (
        // Owner: can update anything except critical fields (ownerId, createdAt, status)
        (isOwner(resource.data.ownerId) 
          && !request.resource.data.keys().hasAny(['ownerId', 'createdAt', 'status']))
        // Moderator: can update anything including status
        || isModerator()
        // Any user: can ONLY increment views/likes/favorites/comments with specific delta operations
        || (request.resource.data.diff(resource.data).affectedKeys().only(['views', 'likes', 'favorites', 'comments']).size() > 0
          && request.resource.data.diff(resource.data).affectedKeys().only(['views', 'likes', 'favorites', 'comments']).size() 
            == request.resource.data.diff(resource.data).affectedKeys().size())
        // Any user: can add/update ratings (only the ratings map and average rating/reviews count)
        || (request.resource.data.diff(resource.data).affectedKeys().only(['ratings', 'rating', 'reviews']).size() > 0
          && request.resource.data.diff(resource.data).affectedKeys().only(['ratings', 'rating', 'reviews']).size() 
            == request.resource.data.diff(resource.data).affectedKeys().size()
          && request.resource.data.rating > 0 && request.resource.data.rating <= 5
          && request.resource.data.reviews >= 0)
      );

      // Delete: owner or moderator
      allow delete: if request.auth != null && (
        isOwner(resource.data.ownerId) || isModerator()
      );
    }

    match /properties/{propertyId}/comments/{commentId} {
      allow read: if true;
      
      // Create: user must match auth user
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      
      // Update: only comment author or moderator
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || isModerator()
      );
      
      // Delete: comment author or moderator
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId || isModerator()
      );
    }

    match /bookings/{bookingId} {
      // Read: any authenticated user can read bookings (needed for date conflict checking and viewing own bookings)
      allow read: if request.auth != null;
      
      // Create: user booking must be created by the authenticated user with 'pending' status
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAny(['propertyId', 'checkInDate', 'checkOutDate', 'totalPrice', 'nights', 'userName', 'userEmail', 'userPhone']);
      
      // Update: authorized users can update with different restrictions based on role
      allow update: if request.auth != null && (
        // Guest can change pending -> cancelled
        (request.auth.uid == resource.data.userId 
         && resource.data.status == 'pending' 
         && request.resource.data.status == 'cancelled')
        // Property owner can change pending -> approved or pending -> rejected
        || (isOwner(get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId)
         && resource.data.status == 'pending'
         && (request.resource.data.status == 'approved' || request.resource.data.status == 'rejected')
         && request.resource.data.keys().hasOnly(['id', 'propertyId', 'userId', 'ownerId', 'userName', 'userEmail', 'userPhone', 'checkInDate', 'checkOutDate', 'nights', 'totalPrice', 'createdAt', 'status', 'approvedAt', 'rejectedAt', 'rejectionReason']))
        // Owner can edit dates for approved bookings (to reschedule)
        || (isOwner(get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId)
         && resource.data.status == 'approved'
         && request.resource.data.keys().hasOnly(['id', 'propertyId', 'userId', 'ownerId', 'userName', 'userEmail', 'userPhone', 'checkInDate', 'checkOutDate', 'nights', 'totalPrice', 'createdAt', 'status', 'approvedAt', 'rejectedAt', 'rejectionReason']))
      );
      
      // Delete: owner/moderator can delete any booking, or user can delete their own cancelled bookings
      allow delete: if request.auth != null && (
        (request.auth.uid == resource.data.userId && resource.data.status == 'cancelled')
        || isOwner(get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId)
        || isModerator()
      );
    }

    match /commentReports/{reportId} {
      // Read: only moderators can read reports (NOT any authenticated user)
      allow read: if request.auth != null && isModerator();
      
      // Create: any authenticated user can report a comment
      allow create: if request.auth != null
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.reportedByName != null
        && request.resource.data.commentId != null
        && request.resource.data.propertyId != null
        && request.resource.data.reason != null;
      
      // Update: moderator can update (close/dismiss reports)
      allow update: if request.auth != null && isModerator();
      
      // Delete: moderator can delete reports
      allow delete: if request.auth != null && isModerator();
    }

    match /cancellationRequests/{requestId} {
      // Read: guest can read their own cancellation requests, or owner can read requests for their properties
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.guestId
        || request.auth.uid == resource.data.ownerId
      );

      // Create: guest must match auth user
      allow create: if request.auth != null
        && request.resource.data.guestId == request.auth.uid
        && request.resource.data.bookingId != null
        && request.resource.data.propertyId != null
        && request.resource.data.ownerId != null
        && request.resource.data.guestName != null
        && request.resource.data.guestEmail != null
        && request.resource.data.checkInDate != null
        && request.resource.data.checkOutDate != null
        && request.resource.data.status == 'pending';

      // Update: only property owner can update status (approve/reject)
      allow update: if request.auth != null
        && isOwner(resource.data.ownerId)
        && (request.resource.data.status == 'approved' || request.resource.data.status == 'rejected')
        && request.resource.data.respondedAt != null;

      // Delete: guest, owner, or moderator can delete
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.guestId
        || request.auth.uid == resource.data.ownerId
        || isModerator()
      );
    }
  }
}