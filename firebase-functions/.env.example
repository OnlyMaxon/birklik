# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Cleanup Settings
CLEANUP_TOKEN=your-secret-token-for-manual-cleanup
CLEANUP_ENABLED=true

# Schedule (cron format)
# Firestore cleanup every Monday at 2 AM UTC
FIRESTORE_CLEANUP_SCHEDULE="0 2 * * 1"

# Storage cleanup every Tuesday at 2 AM UTC  
STORAGE_CLEANUP_SCHEDULE="0 2 * * 2"

# Limits
MAX_DELETES_PER_RUN=100
MIN_AGE_DRAFT_DAYS=30
MIN_AGE_CANCELLED_DAYS=90
MIN_AGE_TEST_DAYS=7
