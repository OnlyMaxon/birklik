# Cache-Control для различных типов файлов

# Service Worker - никогда не кешируем
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/javascript

# HTML - никогда не кешируем
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: text/html; charset=utf-8

# Assets (JS, CSS, images) - кешируем на длительный период
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/javascript

/assets/*.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css

/assets/*.woff*
  Cache-Control: public, max-age=31536000, immutable

/assets/*.png
/assets/*.jpg
/assets/*.jpeg
/assets/*.gif
/assets/*.webp
/assets/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Manifest и другие файлы
/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate

# Cloudflare Workers и функции
/api/*
  Cache-Control: no-store

