{
  "version": 1,
  "include": ["/*"],
  "exclude": [
    "/assets/*",
    "/brand/*",
    "*.js",
    "*.css",
    "*.png",
    "*.jpg",
    "*.jpeg",
    "*.svg",
    "*.gif",
    "*.ico",
    "*.woff",
    "*.woff2",
    "*.ttf",
    "*.eot",
    "*.webp"
  ],
  "rules": [
    {
      "role": "serve",
      "include": ["/assets/*", "/brand/*"],
      "cache": {
        "default_ttl": 31536000,
        "default_cache_control": "public, max-age=31536000, immutable"
      }
    },
    {
      "role": "dynamic"
    }
  ]
}
