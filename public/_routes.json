{
  "version": 1,
  "include": ["/*"],
  "exclude": ["/assets/*", "/brand/*", "*.js", "*.css", "*.ico", "*.png", "*.jpg", "*.jpeg", "*.svg", "*.webp", "*.gif", "*.woff", "*.woff2", "*.ttf", "*.eot"],
  "rules": [
    {
      "role": "serve",
      "include": ["/assets/*", "/brand/*"],
      "cache": {
        "default_ttl": 31536000
      }
    },
    {
      "role": "dynamic"
    }
  ]
}
