{
  "version": 1,
  "include": ["/"],
  "exclude": ["/assets/*", "/brand/*", "*.js", "*.css", "*.ico", "*.png", "*.jpg", "*.jpeg", "*.svg", "*.webp", "*.gif"],
  "rules": [
    {
      "role": "serve",
      "include": ["/assets/*", "/brand/*"],
      "cache": {
        "default_ttl": 31536000,
        "default_cache_control": "public, max-age=31536000, immutable"
      }
    },
    {
      "role": "dynamic"
    }
  ]
}
