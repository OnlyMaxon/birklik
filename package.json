{
  "name": "birklik-az",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/copy-404.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "logo:generate": "node scripts/generate-logo-assets.mjs",
    "functions:build": "cd firebase-functions && npm run build",
    "functions:deploy": "firebase deploy --only functions --project birklik-65289 --force",
    "functions:logs": "firebase functions:log --project birklik-65289",
    "cleanup:dry": "cd firebase-functions && npm run cleanup:dry",
    "cleanup:execute": "cd firebase-functions && npm run cleanup:execute"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "firebase-admin": "^13.8.0",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "vitest": "^1.6.1"
  }
}
